# Server
PORT=8080
GIN_MODE=release
JWT_SECRET=replace-with-strong-secret
# Base URL backend untuk membentuk URL publik file upload lokal.
# Contoh lokal: http://localhost:8080
PUBLIC_BASE_URL=http://localhost:8080

# Dummy admin untuk login lokal (otomatis dibuat saat startup jika belum ada)
ADMIN_EMAIL=admin@cleantrack.local
ADMIN_USERNAME=Admin CleanTrack
ADMIN_PASSWORD=admin123

# Dummy petugas untuk login lokal (otomatis dibuat saat startup jika belum ada)
OFFICER_EMAIL=petugas@cleantrack.local
OFFICER_USERNAME=Petugas CleanTrack
OFFICER_PASSWORD=petugas123

# MySQL (lokal atau RDS)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=reportsampah

# AWS S3
# Jika kredensial AWS tidak diisi, upload otomatis fallback ke penyimpanan lokal ./uploads.
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=cleantrack-reports
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Optional (for temporary credentials)
AWS_SESSION_TOKEN=
